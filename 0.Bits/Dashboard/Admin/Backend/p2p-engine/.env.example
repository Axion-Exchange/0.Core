# ============================================================
# PearV2 — Environment Variables
# ============================================================
# Copy this file to .env and fill in all values.
# DO NOT commit .env — it contains secrets.
#
# Generate API_SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================================

# --- CORE (always required) ---
API_SECRET_KEY=              # Dashboard API key (never auto-generated)
BINANCE_API_KEY=             # Binance P2P API key
BINANCE_API_SECRET=          # Binance P2P API secret

# --- EUR PATH (SEPA payout via Januar) ---
JANUAR_API_KEY=              # Januar API key
JANUAR_API_SECRET=           # Januar API secret

# --- COP PATH (FacilitaPay PSE payments) ---
ENABLE_COP=false              # Set to 'true' to enable COP handler
BINANCE_2FA_SECRET=          # Binance TOTP secret (for crypto release)
FACILITAPAY_USERNAME=        # FacilitaPay account username
FACILITAPAY_PASSWORD=        # FacilitaPay account password
FACILITAPAY_CASH_IN_ACCOUNT_ID=  # FacilitaPay cash-in bank account ID
FACILITAPAY_CASHOUT_ACCOUNT_ID=  # FacilitaPay cash-out bank account ID
FACILITAPAY_WEBHOOK_SECRET=  # FacilitaPay webhook signing secret
GEMINI_API_KEY=              # Google Gemini API key (for chat info extraction)

# --- OPTIONAL ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000  # Comma-separated allowed origins
POLL_INTERVAL=5.0            # EUR order poll interval (seconds)
COP_POLL_INTERVAL=30.0       # COP order poll interval (seconds)
DB_PATH=data/orders.db       # EUR orders database path
COP_DB_PATH=data/cop_orders.db  # COP orders database path
FP_DB_PATH=data/facilitapay.db  # FacilitaPay persistence database path
LOG_LEVEL=INFO               # Logging level (DEBUG, INFO, WARNING, ERROR)
AUTO_SEND_COP_LINK=false     # If true, auto-send PSE links; if false, queue for manual approval
