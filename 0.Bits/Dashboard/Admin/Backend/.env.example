# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zerobits?schema=public"

# ── Auth ────────────────────────────────────────────
JWT_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-64"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── CORS ────────────────────────────────────────────
CORS_ORIGINS="http://localhost:5173,https://0bits-dashboard.axion-164.workers.dev"

# ── Encryption (API keys at rest) ───────────────────
ENCRYPTION_KEY="CHANGE-ME-64-hex-chars-openssl-rand-hex-32"

# ── Exchange Connectors ─────────────────────────────
BINANCE_API_KEY=""
BINANCE_API_SECRET=""
BITGET_API_KEY=""
BITGET_API_SECRET=""
BITGET_PASSPHRASE=""

# ── Fiat Rail Connectors ───────────────────────────
JANUAR_API_KEY=""
JANUAR_API_SECRET=""
FACILITAPAY_USERNAME=""
FACILITAPAY_PASSWORD=""

# ── Logging ─────────────────────────────────────────
LOG_LEVEL="debug"
