# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/zeropool?schema=public"

# JWT
JWT_SECRET="change-me-to-a-real-secret-key-at-least-64-chars-long"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# SMTP (for email verification)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@0pool.io"
SMTP_SENDER="0pool.io"
